{
  "manifest_version": 3,
  "name": "News Filter",
  "version": "1.0",
  "description": "Analyze news articles for bias, opinions, and AI-generated content.",
  "permissions": ["sidePanel", "scripting", "activeTab"],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "Open News Filter",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
